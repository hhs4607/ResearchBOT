# === Required ===
GEMINI_API_KEY=                    # Google Gemini API key for AI extraction
OPENALEX_EMAIL=                    # Email for OpenAlex polite pool (higher rate limits)

# === Recommended ===
S2_API_KEY=                        # Semantic Scholar API key (higher rate limits)

# === Optional ===
CROSSREF_EMAIL=                    # Email for CrossRef polite pool
NCBI_API_KEY=                      # PubMed/NCBI API key (10 req/sec vs 3)
ZOTERO_USER_ID=                    # Zotero user ID for citation sync
ZOTERO_API_KEY=                    # Zotero API key for citation sync
